<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  targetNamespace="http://libreria-microservicios.com/bpmn"
  id="definitions-inventario">

  <bpmn:process id="ProcesoInventario" name="Gestión de Inventario y Reposición" isExecutable="true">
    
    <bpmn:laneSet id="laneSet_03">
      <bpmn:lane id="Lane_AdminInventario" name="Administrador">
        <bpmn:flowNodeRef>StartEvent_Inventario</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConsultarStockForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalizarStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReponerStock</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ActualizarMinimos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_InventarioOK</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_SistemaInventario" name="Inventory Microservice">
        <bpmn:flowNodeRef>Task_ListarInventario</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BuscarProductoInv</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidarStockMinimo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EjecutarReposicion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotificarStockBajo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ActualizarRegistro</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_StockBajo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ValidarLimites</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_BDInventario" name="Base de Datos (PostgreSQL)">
        <bpmn:flowNodeRef>Task_QueryAllInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueryProductInventory</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateStockDB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateMinimosDB</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- EVENTOS -->
    <bpmn:startEvent id="StartEvent_Inventario" name="Inicio sesión admin">
      <bpmn:outgoing>Flow_Start_Consultar</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_InventarioOK" name="Operación completada">
      <bpmn:incoming>Flow_Repo_OK_Fin</bpmn:incoming>
      <bpmn:incoming>Flow_Minimos_OK_Fin</bpmn:incoming>
      <bpmn:incoming>Flow_FinDirecto</bpmn:incoming>
    </bpmn:endEvent>

    <!-- TAREAS ADMIN -->
    <bpmn:userTask id="Task_ConsultarStockForm" name="Consultar stock actual" camunda:assignee="admin">
      <bpmn:incoming>Flow_Start_Consultar</bpmn:incoming>
      <bpmn:outgoing>Flow_Consultar_Listar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AnalizarStock" name="Analizar niveles de inventario" camunda:assignee="admin">
      <bpmn:incoming>Flow_DatosStock_Result</bpmn:incoming>
      <bpmn:outgoing>Flow_Analizar_Decision</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ReponerStock" name="Ingresar cantidad a reponer" camunda:assignee="admin">
      <bpmn:incoming>Flow_Decision_Reponer</bpmn:incoming>
      <bpmn:outgoing>Flow_Reponer_Ejecutar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ActualizarMinimos" name="Actualizar stock mínimo/máximo" camunda:assignee="admin">
      <bpmn:incoming>Flow_Decision_Minimos</bpmn:incoming>
      <bpmn:outgoing>Flow_Minimos_Actualizar</bpmn:outgoing>
    </bpmn:userTask>

    <!-- GATEWAYS ADMIN -->
    <bpmn:exclusiveGateway id="Gateway_Decision" name="¿Qué acción realizar?">
      <bpmn:incoming>Flow_Analizar_Decision</bpmn:incoming>
      <bpmn:outgoing>Flow_Decision_Reponer</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Minimos</bpmn:outgoing>
      <bpmn:outgoing>Flow_Decision_Fin</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- TAREAS SISTEMA -->
    <bpmn:serviceTask id="Task_ListarInventario" name="GET /api/v1/inventory">
      <bpmn:incoming>Flow_Consultar_Listar</bpmn:incoming>
      <bpmn:outgoing>Flow_Listar_BD</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_BuscarProductoInv" name="GET /api/v1/inventory/product/{id}">
      <bpmn:incoming>Flow_ListarProducto</bpmn:incoming>
      <bpmn:outgoing>Flow_BuscarProd_BD</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ValidarStockMinimo" name="Verificar si stock ≤ stock_minimo">
      <bpmn:incoming>Flow_DatosStock_Verificar</bpmn:incoming>
      <bpmn:outgoing>Flow_Validar_Result</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_EjecutarReposicion" name="PATCH /api/v1/inventory/{id}/add?quantity=n">
      <bpmn:incoming>Flow_Reponer_Validar</bpmn:incoming>
      <bpmn:outgoing>Flow_Repo_BD</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_NotificarStockBajo" name="Enviar alerta de stock bajo">
      <bpmn:incoming>Flow_Bajo_Notificar</bpmn:incoming>
      <bpmn:outgoing>Flow_Notificar_Fin</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ActualizarRegistro" name="PUT /api/v1/inventory/{id}">
      <bpmn:incoming>Flow_Minimos_ActualizarSist</bpmn:incoming>
      <bpmn:outgoing>Flow_ActualizarReg_BD</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- GATEWAYS SISTEMA -->
    <bpmn:exclusiveGateway id="Gateway_StockBajo" name="¿Stock < mínimo?">
      <bpmn:incoming>Flow_BuscarProd_BD_Result</bpmn:incoming>
      <bpmn:incoming>Flow_QueryProdInv_Result</bpmn:incoming>
      <bpmn:outgoing>Flow_Bajo_Correcto</bpmn:outgoing>
      <bpmn:outgoing>Flow_Bajo_Notificar</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_ValidarLimites" name="¿Cantidad ≤ stock_maximo - stock_actual?">
      <bpmn:incoming>Flow_Repo_BD_Ok</bpmn:incoming>
      <bpmn:outgoing>Flow_ValLim_OK</bpmn:outgoing>
      <bpmn:outgoing>Flow_ValLim_Error</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- TAREAS BD -->
    <bpmn:serviceTask id="Task_QueryAllInventory" name="SELECT * FROM inventory_tb">
      <bpmn:incoming>Flow_Listar_BD</bpmn:incoming>
      <bpmn:outgoing>Flow_BD_Listado_Result</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_QueryProductInventory" name="SELECT * FROM inventory_tb WHERE product_id = ?">
      <bpmn:incoming>Flow_BuscarProd_BD</bpmn:incoming>
      <bpmn:outgoing>Flow_QueryProdInv_Result</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UpdateStockDB" name="UPDATE inventory SET quantity = ? WHERE id = ?">
      <bpmn:incoming>Flow_Repo_DB</bpmn:incoming>
      <bpmn:outgoing>Flow_Repo_BD_Ok</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UpdateMinimosDB" name="UPDATE inventory SET stock_min = ?, stock_max = ? WHERE id = ?">
      <bpmn:incoming>Flow_ActualizarReg_BD</bpmn:incoming>
      <bpmn:outgoing>Flow_Minimos_BD_OK</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- FLUJOS -->
    <bpmn:sequenceFlow id="Flow_Start_Consultar" sourceRef="StartEvent_Inventario" targetRef="Task_ConsultarStockForm" />
    <bpmn:sequenceFlow id="Flow_Consultar_Listar" sourceRef="Task_ConsultarStockForm" targetRef="Task_ListarInventario" />
    <bpmn:sequenceFlow id="Flow_Listar_BD" sourceRef="Task_ListarInventario" targetRef="Task_QueryAllInventory" />
    <bpmn:sequenceFlow id="Flow_BD_Listado_Result" sourceRef="Task_QueryAllInventory" targetRef="Task_AnalizarStock" />
    <bpmn:sequenceFlow id="Flow_Analizar_Decision" sourceRef="Task_AnalizarStock" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_Decision_Reponer" sourceRef="Gateway_Decision" targetRef="Task_ReponerStock" name="Reponer" />
    <bpmn:sequenceFlow id="Flow_Decision_Minimos" sourceRef="Gateway_Decision" targetRef="Task_ActualizarMinimos" name="Ajustar mínimos" />
    <bpmn:sequenceFlow id="Flow_Decision_Fin" sourceRef="Gateway_Decision" targetRef="EndEvent_InventarioOK" name="Salir" />
    <bpmn:sequenceFlow id="Flow_Reponer_Ejecutar" sourceRef="Task_ReponerStock" targetRef="Task_BuscarProductoInv" />
    <bpmn:sequenceFlow id="Flow_ListarProducto" sourceRef="Task_ReponerStock" targetRef="Task_BuscarProductoInv" />
    <bpmn:sequenceFlow id="Flow_BuscarProd_BD" sourceRef="Task_BuscarProductoInv" targetRef="Task_QueryProductInventory" />
    <bpmn:sequenceFlow id="Flow_QueryProdInv_Result" sourceRef="Task_QueryProductInventory" targetRef="Gateway_StockBajo" />
    <bpmn:sequenceFlow id="Flow_Bajo_Correcto" sourceRef="Gateway_StockBajo" targetRef="Task_EjecutarReposicion" name="Stock OK" />
    <bpmn:sequenceFlow id="Flow_Bajo_Notificar" sourceRef="Gateway_StockBajo" targetRef="Task_NotificarStockBajo" name="Stock bajo" />
    <bpmn:sequenceFlow id="Flow_Notificar_Fin" sourceRef="Task_NotificarStockBajo" targetRef="EndEvent_InventarioOK" />
    <bpmn:sequenceFlow id="Flow_Reponer_Validar" sourceRef="Task_EjecutarReposicion" targetRef="Gateway_ValidarLimites" />
    <bpmn:sequenceFlow id="Flow_Repo_DB" sourceRef="Gateway_ValidarLimites" targetRef="Task_UpdateStockDB" name="Válido" />
    <bpmn:sequenceFlow id="Flow_ValLim_Error" sourceRef="Gateway_ValidarLimites" targetRef="EndEvent_InventarioOK" name="Excede máximo" />
    <bpmn:sequenceFlow id="Flow_Repo_BD_Ok" sourceRef="Task_UpdateStockDB" targetRef="EndEvent_InventarioOK" />
    <bpmn:sequenceFlow id="Flow_Minimos_Actualizar" sourceRef="Task_ActualizarMinimos" targetRef="Task_ActualizarRegistro" />
    <bpmn:sequenceFlow id="Flow_Minimos_ActualizarSist" sourceRef="Task_ActualizarMinimos" targetRef="Task_ActualizarRegistro" />
    <bpmn:sequenceFlow id="Flow_ActualizarReg_BD" sourceRef="Task_ActualizarRegistro" targetRef="Task_UpdateMinimosDB" />
    <bpmn:sequenceFlow id="Flow_Minimos_BD_OK" sourceRef="Task_UpdateMinimosDB" targetRef="EndEvent_InventarioOK" />

    <!-- FLUJOS AUX -->
    <bpmn:sequenceFlow id="Flow_DatosStock_Verificar" sourceRef="Task_ConsultarStockForm" targetRef="Task_ValidarStockMinimo" />
    <bpmn:sequenceFlow id="Flow_Validar_Result" sourceRef="Task_ValidarStockMinimo" targetRef="Task_AnalizarStock" />
    <bpmn:sequenceFlow id="Flow_DatosStock_Result" sourceRef="Task_ValidarStockMinimo" targetRef="Task_AnalizarStock" />
    <bpmn:sequenceFlow id="Flow_FinDirecto" sourceRef="Task_ListarInventario" targetRef="EndEvent_InventarioOK" />
    <bpmn:sequenceFlow id="Flow_Repo_OK_Fin" sourceRef="Task_UpdateStockDB" targetRef="EndEvent_InventarioOK" />
    <bpmn:sequenceFlow id="Flow_Minimos_OK_Fin" sourceRef="Task_UpdateMinimosDB" targetRef="EndEvent_InventarioOK" />
    <bpmn:sequenceFlow id="Flow_ValLim_OK" sourceRef="Gateway_ValidarLimites" targetRef="Task_UpdateStockDB" name="Válido" />
    <bpmn:sequenceFlow id="Flow_BuscarProd_BD_Result" sourceRef="Task_QueryProductInventory" targetRef="Gateway_StockBajo" />

  </bpmn:process>
</bpmn:definitions>
